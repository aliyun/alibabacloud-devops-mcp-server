              "type": "string"
            },
            "example": "589c53d622cc8521793e08****"
          },
          {
            "name": "id",
            "in": "path",
            "description": "版本唯一标识",
            "required": true,
            "schema": {
              "type": "string"
            },
            "example": "bfbb5f44f3aaab11460cd1****"
          },
          {
            "name": "organizationId",
            "in": "path",
            "description": "organizationId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateVersionRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK"
          }
        }
      },
      "delete": {
        "tags": [
          "版本"
        ],
        "summary": "删除版本",
        "operationId": "DeleteVersion",
        "parameters": [
          {
            "name": "projectId",
            "in": "path",
            "description": "项目唯一标识",
            "required": true,
            "schema": {
              "type": "string"
