          },
          {
            "name": "id",
            "in": "path",
            "description": "版本唯一标识",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organizationId",
            "in": "path",
            "description": "organizationId",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/OperatorIdRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK"
