        "title": "AttachmentDTO",
        "type": "object",
        "properties": {
          "creator": {
            "description": "创建人",
            "$ref": "#/components/schemas/MiniUser"
          },
          "fileId": {
            "type": "string",
            "description": "文件id",
            "example": "985353d622cc8521793e08****"
          },
          "fileName": {
            "type": "string",
            "description": "文件名称",
            "example": "file-name-xxx"
          },
          "gmtCreate": {
            "type": "string",
            "description": "创建时间",
            "format": "date-time"
          },
          "gmtModified": {
            "type": "string",
            "description": "修改时间",
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "description": "id",
            "example": "id-xxx"
          },
          "modifier": {
            "description": "修改人",
            "$ref": "#/components/schemas/MiniUser"
          },
          "size": {
            "type": "integer",
            "description": "文件大小",
            "format": "int32",
            "example": 1024
          },
          "suffix": {
            "type": "string",
            "description": "文件后缀",
            "example": ".png"
          },
          "url": {
            "type": "string",
            "description": "文件下载地址，是个临时的下载地址，有实效性",
            "example": "https://xxx.test.com"
          }
        }
      },
      "MiniUser": {
        "title": "MiniUser",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "用户id",
            "example": "674d96abd497cd558d68****"
          },
          "name": {
            "type": "string",
            "description": "名称",
            "example": "name-xxx"
          }
        }
