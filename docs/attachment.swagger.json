{
  "openapi": "3.0.3",
  "info": {
    "title": "工作项附件 Open API",
    "description": "项目协作工作项附件相关接口",
    "version": "1.0.0"
  },
  "servers": [],
  "tags": [
    {
      "name": "工作项附件",
      "description": "项目协作工作项附件相关接口"
    }
  ],
  "paths": {
    "/projex/organizations/{organizationId}/workitems/{id}/attachments": {
      "get": {
        "tags": [
          "工作项附件"
        ],
        "summary": "获取工作项附件列表",
        "operationId": "ListWorkitemAttachments",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "工作项唯一标识",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organizationId",
            "in": "path",
            "description": "organizationId",
            "required": true,
            "style": "simple",
            "allowReserved": false,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/AttachmentDTO"
                  }
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      },
      "post": {
        "tags": [
          "工作项附件"
        ],
        "summary": "上传工作项附件",
        "operationId": "CreateWorkitemAttachment",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "description": "工作项唯一标识",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "organizationId",
            "in": "path",
            "description": "organizationId",
            "required": true,
            "schema": { "type": "string" },
            "description": "工作项唯一标识"
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "required": [
                  "file"
                ],
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "待上传文件"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "成功",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkitemFile" }
              }
            }
          },
          "201": {
            "description": "Created"
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    },
    "/projex/organizations/{organizationId}/workitems/{workitemId}/files/{id}": {
      "get": {
        "tags": [
          "工作项附件"
        ],
        "summary": "获取工作文件信息",
        "operationId": "GetWorkitemFile",
        "parameters": [
          {
            "name": "organizationId",
            "in": "path",
            "description": "organizationId",
            "required": true,
            "style": "simple",
            "allowReserved": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "workitemId",
            "in": "path",
            "description": "工作项唯一标识",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "id",
            "in": "path",
            "description": "文件唯一标识",
            "required": true,
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/WorkitemFile"
                }
              }
            }
          },
          "401": {
            "description": "Unauthorized"
          },
          "403": {
            "description": "Forbidden"
          },
          "404": {
            "description": "Not Found"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AttachmentDTO": {
        "title": "AttachmentDTO",
        "type": "object",
        "properties": {
          "creator": {
            "description": "创建人",
            "$ref": "#/components/schemas/MiniUser"
          },
          "fileId": {
            "type": "string",
            "description": "文件id",
            "example": "985353d622cc8521793e08****"
          },
          "fileName": {
            "type": "string",
            "description": "文件名称",
            "example": "file-name-xxx"
          },
          "gmtCreate": {
            "type": "string",
            "description": "创建时间",
            "format": "date-time"
          },
          "gmtModified": {
            "type": "string",
            "description": "修改时间",
            "format": "date-time"
          },
          "id": {
            "type": "string",
            "description": "文件id",
            "example": "985353d622cc8521793e08****"
          },
          "modifier": {
            "description": "修改人",
            "$ref": "#/components/schemas/MiniUser"
          },
          "size": {
            "type": "integer",
            "description": "文件大小",
            "format": "int32",
            "example": 1024
          },
          "suffix": {
            "type": "string",
            "description": "文件后缀",
            "example": ".png"
          },
          "url": {
            "type": "string",
            "description": "文件下载地址，是个临时的下载地址，有实效性",
            "example": "https://xxx.test.com"
          }
        }
      },
      "MiniUser": {
        "title": "MiniUser",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "用户id",
            "example": "674d96abd497cd558d68****"
          },
          "name": {
            "type": "string",
            "description": "名称",
            "example": "name-xxx"
          }
        }
      },
      "WorkitemFile": {
        "title": "WorkitemFile",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "文件id",
            "example": "985353d622cc8521793e08****"
          },
          "name": {
            "type": "string",
            "description": "名称",
            "example": "name-xxx"
          },
          "size": {
            "type": "integer",
            "description": "大小",
            "format": "int32",
            "example": 1024
          },
          "suffix": {
            "type": "string",
            "description": "后缀",
            "example": ".png"
          },
          "url": {
            "type": "string",
            "description": "文件下载地址，是个临时的下载地址，有实效性",
            "example": "https://xxx.test.com"
          }
        }
      }
    }
  }
}