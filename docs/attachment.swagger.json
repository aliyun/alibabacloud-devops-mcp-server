      "WorkitemFile": {
        "title": "WorkitemFile",
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "id",
            "example": "id-xxx"
          },
          "name": {
            "type": "string",
            "description": "名称",
            "example": "name-xxx"
          },
          "size": {
            "type": "integer",
            "description": "大小",
            "format": "int32",
            "example": 1024
          },
          "suffix": {
            "type": "string",
            "description": "后缀",
            "example": ".png"
          },
          "url": {
            "type": "string",
