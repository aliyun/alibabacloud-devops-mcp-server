  "components": {
    "schemas": {
      "CreateProjectRequest": {
        "required": [
          "customCode",
          "name",
          "scope",
          "templateId"
        ],
        "type": "object",
        "properties": {
          "operatorId": {
            "type": "string",
            "description": "操作者的userId，个人token时该参数无效",
            "example": "user-xxx",
            "default": "操作者的id，个人token时该参数无效"
          },
          "name": {
            "type": "string",
            "description": "项目名称",
            "example": "project-test"
          },
          "scope": {
            "type": "string",
            "description": "公开性, public or private",
            "example": "public",
            "enum": [
              "public, private"
            ]
          },
          "customCode": {
            "type": "string",
            "description": "项目编号，四到六位大写字母，组织下唯一",
            "example": "CCDD"
          },
          "description": {
            "type": "string",
            "description": "描述",
            "example": "test"
          },
          "customFieldValues": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "description": "格式为:{\"fieldId\":\"value\"}，多值value用逗号隔开，例如：{\"fieldId\": \"value1,value2\"}。例如：{\"priority\":\"888853d622cc8eae793e085e27\"}。fieldId的可选值为\"获取项目模板\"接口返回的字段type值为CustomField的字段，value为希望更新的值。 ",
              "example": {
                "priority": "888853d622cc8eae793e085e27"
              }
            },
            "description": "格式为:{\"fieldId\":\"value\"}，多值value用逗号隔开，例如：{\"fieldId\": \"value1,value2\"}。例如：{\"priority\":\"888853d622cc8eae793e085e27\"}。fieldId的可选值为\"获取项目模板\"接口返回的字段type值为CustomField的字段，value为希望更新的值。 ",
            "example": {
              "priority": "888853d622cc8eae793e085e27"
            }
          },
          "templateId": {
            "type": "string",
            "description": "模板id，可以通过获取项目模版列表接口获取",
            "example": "template-test"
          }
        }
      },
      "IdentifierDTO": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "description": "id",
            "example": "1111"
          }
        }
      },
      "SearchProjectRequest": {
        "type": "object",
        "properties": {
          "conditions": {
            "type": "string",
            "description": "过滤条件， 是一个json串，格式为{\"conditionGroups\":[[filterObject,filterObject,...]]}， 目前支持name,status,gmtCreate,creator,project.admin,logicalStatus六个条件搜索，以下为一个完整的搜索条件(真实场景中可以按需选取对应的值){\"conditionGroups\":[[{\"className\":\"status\",\"fieldIdentifier\":\"status\",\"format\":\"list\",\"operator\":\"CONTAINS\",\"toValue\":null,\"value\":[\"8a4058a71159b682541b0864\",\"cc961a18adf770c6e423ccc5\",\"faf4893ebf92851b6717511a9e\",\"e22f2f8dcbffe9aa03eae7e8ba\"]},{\"className\":\"string\",\"fieldIdentifier\":\"name\",\"format\":\"input\",\"operator\":\"BETWEEN\",\"toValue\":null,\"value\":[\"ffffff\"]},{\"className\":\"date\",\"fieldIdentifier\":\"gmtCreate\",\"format\":\"input\",\"operator\":\"BETWEEN\",\"toValue\":\"2023-09-06 23:59:59\",\"value\":[\"2023-08-03 00:00:00\"]},{\"className\":\"user\",\"fieldIdentifier\":\"creator\",\"format\":\"list\",\"operator\":\"CONTAINS\",\"toValue\":null,\"value\":[\"43578d02-c84c-4fef-8c34-50c05304809a\",\"d222d052-4c0e-4a03-b961-bb3f5fd556a0\"]},{\"className\":\"user\",\"fieldIdentifier\":\"project.admin\",\"format\":\"multiList\",\"operator\":\"CONTAINS\",\"toValue\":null,\"value\":[\"d222d052-4c0e-4a03-b961-bb3f5fd556a0\",\"bccd35ab-6380-4e03-b280-8b6f966e635c\"]},{\"className\":\"string\",\"fieldIdentifier\":\"logicalStatus\",\"format\":\"list\",\"operator\":\"CONTAINS\",\"toValue\":null,\"value\":[\"NORMAL\"]}]]}",
            "example": "{\"conditionGroups\":[[{\"className\":\"string\",\"fieldIdentifier\":\"name\",\"format\":\"input\",\"operator\":\"BETWEEN\",\"toValue\":null,\"value\":[\"test\"]}]]}"
          },
          "extraConditions": {
            "type": "string",
            "description": "额外的过滤条件，该参数主要设定一个基础查询范围，例如我管理的、我参与的，我收藏的等。 可以参考页面的项目列表的ajax接口project/search/list中的extraConditions参数",
            "example": ""
          },
          "page": {
            "minimum": 1,
            "type": "integer",
            "description": "分页参数，第几页",
            "format": "int32",
            "example": 1
          },
          "perPage": {
            "maximum": 200,
            "type": "integer",
            "description": "分页参数，每页大小，0-200，默认值20",
            "format": "int32",
            "example": 20
          },
          "orderBy": {
            "type": "string",
            "description": "排序字段，目前只支持名称和创建时间，不填值则默认为gmtCreate, gmtCreate：创建时间,name：名称",
            "example": "gmtCreate"
          },
          "sort": {
            "type": "string",
            "description": "排序方式，默认为desc，desc对应降序; asc对应升序",
            "example": "desc"
          }
        }
      },
      "FieldDisplayValue": {
        "type": "object",
        "properties": {
          "identifier": {
            "type": "string",
            "description": "值的唯一标识",
            "example": "111"
          },
          "displayValue": {
            "type": "string",
            "description": "值的显示名称",
            "example": "111"
          }
        }
      },
