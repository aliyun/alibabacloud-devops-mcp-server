{
  "openapi": "3.0.1",
  "info": {
    "title": "AppStack Change Request API",
    "description": "AppStack 变更相关 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://devops.aliyun.com",
      "description": "Production server"
    }
  ],
  "paths": {
    "/appstack/organizations/{organizationId}/apps/{appName}/changeRequests": {
      "post": {
        "operationId": "CreateChangeRequest",
        "parameters": [
          {
            "description": "应用名",
            "example": "my-web-service",
            "in": "path",
            "name": "appName",
            "required": true,
            "schema": {
              "description": "应用名",
              "example": "my-web-service",
              "type": "string"
            }
          },
          {
            "description": "组织ID",
            "example": "ec766e63aee3437d9a51f334d6exe671",
            "in": "path",
            "name": "organizationId",
            "required": true,
            "schema": {
              "example": "ec766e63aee3437d9a51f334d6exe671",
              "type": "string"
            },
            "style": "simple"
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateChangeRequestRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/ChangeRequestVO"
                }
              }
            },
            "description": "创建变更成功"
          },
          "500": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/YunxiaoErrorResponse"
                }
              }
            },
            "description": "变更创建失败 / 服务端内部异常"
          }
        },
        "summary": "创建变更",
        "tags": [
          "变更"
        ]
      }
    },
    "/appstack/organizations/{organizationId}/apps/{appName}/changeRequests:search": {
      "post": {
        "operationId": "ListAppChangeRequests",
        "parameters": [
