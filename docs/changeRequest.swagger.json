    "/appstack/organizations/{organizationId}/apps/{appName}/changeRequests/{sn}/auditItems": {
      "get": {
        "operationId": "GetChangeRequestAuditItems",
        "parameters": [
          {
            "description": "应用名",
            "example": "my-web-service",
            "in": "path",
            "name": "appName",
            "required": true,
            "schema": {
              "description": "应用名",
              "example": "my-web-service",
              "type": "string"
            }
          },
          {
            "description": "变更标识符",
            "example": "f1e78f22428e4e2496a01691812a17af",
            "in": "path",
            "name": "sn",
            "required": true,
            "schema": {
              "description": "变更标识符",
              "example": "f1e78f22428e4e2496a01691812a17af",
              "type": "string"
            }
          },
          {
            "description": "关联类型",
            "example": "CR",
            "in": "query",
            "name": "refType",
            "required": true,
            "schema": {
              "description": "关联类型",
              "example": "CR",
              "type": "string"
            }
          },
          {
            "description": "组织ID",
            "example": "ec766e63aee3437d9a51f334d6exe671",
            "in": "path",
            "name": "organizationId",
            "required": true,
            "schema": {
              "example": "ec766e63aee3437d9a51f334d6exe671",
              "type": "string"
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "*/*": {
                "schema": {
                  "items": {
                    "oneOf": [
                      {
                        "$ref": "#/components/schemas/CodeReviewAuditItem"
                      },
                      {
                        "$ref": "#/components/schemas/CodeSplcAuditItem"
                      }
                    ]
                  },
                  "type": "array"
                }
              }
            },
            "description": "查找变更关联的审批项列表"
