  "components": {
    "schemas": {
      "CreateChangeRequestRequest": {
        "description": "创建变更请求",
        "properties": {
          "appCodeRepoSn": {
            "description": "应用代码仓库标识符",
            "example": "app-code-repo-sn-xxxx",
            "type": "string"
          },
          "autoDeleteBranchWhenEnd": {
            "description": "变更结束时候是否自动删除分支",
            "example": false,
            "type": "boolean"
          },
          "branchName": {
            "description": "应用代码分支名称",
            "example": "master",
            "type": "string"
          },
          "createBranch": {
            "description": "是否创建分支",
            "example": false,
            "type": "boolean"
          },
          "ownerAccountId": {
            "description": "变更负责人账号",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "ownerId": {
            "description": "变更负责人",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "title": {
            "description": "变更标题",
            "example": "title-xxxx",
            "type": "string"
          }
        },
        "required": [
          "appCodeRepoSn",
          "autoDeleteBranchWhenEnd",
          "branchName",
          "createBranch",
          "title"
        ],
        "type": "object"
      },
      "ChangeRequestVO": {
        "description": "变更信息",
        "properties": {
          "appCodeRepoSn": {
            "description": "代码仓库唯一标识",
            "example": "my-web-app-repo",
            "type": "string"
          },
          "appName": {
            "description": "应用名",
            "example": "my-web-service",
            "type": "string"
          },
          "autoDeleteBranchWhenEnd": {
            "description": "结束后是否自动删除分支",
            "example": true,
            "type": "boolean"
          },
          "branch": {
            "description": "变更代码分支",
            "example": "master",
            "type": "string"
          },
          "creatorAccountId": {
            "description": "创建者的阿里云账号pk",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "creatorId": {
            "description": "创建者者云效id",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "gmtCreate": {
            "description": "创建时间",
            "example": "2024-09-01 00:00:00",
            "type": "string"
          },
          "gmtModified": {
            "description": "修改时间",
            "example": "2024-09-01 00:00:00",
            "type": "string"
          },
          "name": {
            "description": "变更名称",
            "example": "my-cr",
            "type": "string"
          },
          "originBranch": {
            "description": "代码分支源分支",
            "example": "master",
            "type": "string"
          },
          "originBranchRevisionSha": {
            "description": "代码分支源分支版本",
            "example": "c229f22024535638af41838daa43af1e6d468116",
            "type": "string"
          },
          "ownerAccountId": {
            "description": "拥有者的阿里云账号pk",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "ownerId": {
            "description": "拥有者ID",
            "example": "10df6011-2837-4fdb-ad92-356a679a60ca",
            "type": "string"
          },
          "sn": {
            "description": "唯一标识符",
            "example": "cde06968-68e6-4122-a769-abda138d7c62",
            "type": "string"
          },
          "state": {
