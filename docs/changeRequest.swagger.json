    "/appstack/organizations/{organizationId}/systems/{systemName}/releases/{releaseSn}/changeRequests": {
      "get": {
        "operationId": "ListAttachedChangeRequests",
        "parameters": [
          {
            "in": "path",
            "example": "systemName",
            "name": "systemName",
            "required": true,
            "schema": {
              "example": "systemName",
              "type": "string"
            }
          },
          {
            "in": "path",
            "example": "anyReleaseWorkflowSn",
            "name": "releaseSn",
            "required": true,
            "schema": {
              "example": "anyReleaseWorkflowSn",
              "type": "string"
            }
          },
          {
            "in": "query",
            "example": 1,
            "name": "current",
            "required": true,
            "schema": {
              "example": 1,
              "default": 1,
              "format": "int64",
              "type": "integer"
            }
          },
          {
            "in": "query",
            "example": 10,
            "name": "pageSize",
            "required": true,
            "schema": {
              "example": 10,
              "default": 10,
              "format": "int64",
              "type": "integer"
