          "变更"
        ]
      }
    },
    "/appstack/organizations/{organizationId}/apps/{appName}/changeRequests/{sn}/executions": {
      "get": {
        "operationId": "ListChangeRequestExecutions",
        "parameters": [
          {
            "description": "应用名",
            "example": "my-web-service",
            "in": "path",
            "name": "appName",
            "required": true,
            "schema": {
              "description": "应用名",
              "example": "my-web-service",
              "type": "string"
            }
          },
          {
            "description": "变更标识符",
            "example": "f1e78f22428e4e2496a01691812a17af",
            "in": "path",
            "name": "sn",
            "required": true,
            "schema": {
              "description": "变更标识符",
              "example": "f1e78f22428e4e2496a01691812a17af",
              "type": "string"
            }
          },
          {
            "description": "分页尺寸参数，决定一页最多返回多少对象",
            "example": 20,
            "in": "query",
            "name": "perPage",
            "required": false,
            "schema": {
              "default": 20,
              "description": "分页尺寸参数，决定一页最多返回多少对象",
              "example": 20,
              "maximum": 100,
              "minimum": 1,
              "type": "number"
            }
          },
          {
            "description": "页面分页时使用，用于获取下一页内容，默认第1页",
            "example": 1,
            "in": "query",
            "name": "page",
            "required": false,
            "schema": {
              "description": "页面分页时使用，用于获取下一页内容，默认第1页",
              "example": 1,
              "type": "number"
            }
          },
          {
            "description": "分页排序属性，决定根据何种属性进行记录排序；推荐在实现严格遍历时，使用 id 属性",
            "example": "id",
            "in": "query",
            "name": "orderBy",
            "required": false,
            "schema": {
              "description": "分页排序属性，决定根据何种属性进行记录排序；推荐在实现严格遍历时，使用 id 属性",
              "enum": [
                "id",
                "gmtCreate"
              ],
              "example": "id",
              "type": "string"
            }
          },
          {
            "description": "分页排序升降序，asc 为升序，desc 为降序；推荐在实现严格遍历时，使用升序",
            "example": "asc",
            "in": "query",
            "name": "sort",
            "required": false,
            "schema": {
              "description": "分页排序升降序，asc 为升序，desc 为降序；推荐在实现严格遍历时，使用升序",
              "enum": [
                "asc",
                "desc"
              ],
              "example": "asc",
              "type": "string"
            }
          },
          {
            "description": "流程唯一标识",
            "example": "1484e1facb5a4febbe1652607b2eb345",
            "in": "query",
            "name": "releaseWorkflowSn",
            "required": true,
            "schema": {
              "description": "流程唯一标识",
              "example": "1484e1facb5a4febbe1652607b2eb345",
              "type": "string"
            }
          },
          {
            "description": "阶段唯一标识",
            "example": "3cfe6717e3dd2379a8ace4ea6a773e7d",
            "in": "query",
            "name": "releaseStageSn",
            "required": true,
            "schema": {
              "description": "阶段唯一标识",
              "example": "3cfe6717e3dd2379a8ace4ea6a773e7d",
              "type": "string"
            }
          },
          {
            "description": "组织ID",
            "example": "ec766e63aee3437d9a51f334d6exe671",
            "in": "path",
            "name": "organizationId",
            "required": true,
            "schema": {
              "example": "ec766e63aee3437d9a51f334d6exe671",
              "type": "string"
            },
            "style": "simple"
          }
        ],
        "responses": {
          "200": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaginationChangeRequestExecutionVO"
                }
              }
            },
            "description": "查询变更研发流程运行记录成功"
          },
          "500": {
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/YunxiaoErrorResponse"
                }
              }
            },
            "description": "服务端内部异常"
          }
        },
        "summary": "查询变更研发流程运行记录",
        "tags": [
          "变更"
        ]
      }
    },
